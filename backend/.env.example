# ==========================================
# BaatCheet Backend — Environment Variables
# ==========================================
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to GitHub.

# ----- Server -----
PORT=5001
NODE_ENV=production

# ----- MongoDB Atlas -----
# Get this from: Atlas Dashboard → Connect → Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/baatcheet?retryWrites=true&w=majority

# ----- CORS / Frontend URL -----
# Set this to your Vercel deployment URL (e.g. https://baatcheet.vercel.app)
CLIENT_URL=https://your-vercel-app.vercel.app

# ----- News API -----
# Get from: https://newsdata.io/
NEWSDATA_API_KEY=your_newsdata_api_key_here

# ----- Email (OTP) -----
# Currently uses Ethereal (auto-generated test accounts) — no config needed for dev.
# For production, replace emailService.js with real SMTP or SendGrid credentials.
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@example.com
# EMAIL_PASS=your_email_password
